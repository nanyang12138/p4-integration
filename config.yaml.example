# P4 Integration Tool - Configuration Example
# 
# This file is optional! All settings have sensible defaults.
# 
# Most settings are configured via the UI:
# - Login: P4 username and password
# - Settings: SSH Host, Master Host, Python Path
# - Job Submit: P4 Client, P4 Port, Workspace, Branch Spec
#
# Environment variables (optional):
# - LOG_LEVEL: DEBUG, INFO, WARNING, ERROR (default: INFO)
# - LOG_FILE: Log file path (default: data/p4_integ.log)
# - P4_INTEG_DATA_DIR: Data directory (default: data/)
#
# You can override defaults here if needed:
#
# logging:
#   level: DEBUG
#   file: /var/log/p4_integ.log
#   max_bytes: 10485760  # 10MB
#   backup_count: 10
#
# data_dir: /var/lib/p4_integ/data
#
# build:
#   # Build / test stage executed BEFORE shelve.
#   # If 'command' is empty or this section is omitted, the BUILD stage is skipped.
#   # On Cancel Job we send SIGTERM to the whole process group, so any local
#   # children of this command die immediately. When lsf_cleanup is true, we also
#   # diff `bjobs` snapshots before/after and `bkill` any LSF jobs spawned during
#   # this BUILD stage (assumes this user does not submit other LSF jobs in the
#   # meantime - typical for a dedicated build host).
#   command: |
#     source /proj/verif_release_ro/cbwa_initscript/current/cbwa_init.bash && \
#     bootenv && \
#     clobber all && \
#     bdji -c -m 8 -v -J lsf -e connectivity::bia_ifrit_logical_view_flow.build -DCOPY_REP
#   lsf_cleanup: true
