# P4 Integration Tool - Configuration Example
# 
# This file is optional! All settings have sensible defaults.
# 
# Most settings are configured via the UI:
# - Login: P4 username and password
# - Settings: SSH Host, Master Host, Python Path
# - Job Submit: P4 Client, P4 Port, Workspace, Branch Spec
#
# Environment variables (optional):
# - LOG_LEVEL: DEBUG, INFO, WARNING, ERROR (default: INFO)
# - LOG_FILE: Log file path (default: data/p4_integ.log)
# - P4_INTEG_DATA_DIR: Data directory (default: data/)
#
# You can override defaults here if needed:
#
# logging:
#   level: DEBUG
#   file: /var/log/p4_integ.log
#   max_bytes: 10485760  # 10MB
#   backup_count: 10
#
# data_dir: /var/lib/p4_integ/data
#
# p4:
#   bin: /tool/pandora64/bin/p4      # Path to the p4 binary
#
# p4push:
#   init_script: /proj/verif_release_ro/cbwa_initscript/current/cbwa_init.bash
#
# job:
#   timeout_hours: 4                 # Max hours a job can run before being cancelled
#
# name_check:
#   max_passes: 5                    # Max name_check remediation passes during SHELVE
